PORT=3000
HOST=0.0.0.0
# You can also place the API key in `../apikey.txt` or `./apikey.txt` for local testing.
# Alibaba Bailian OpenAI-compatible endpoint (China mainland default)
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=replace-with-your-api-key
LLM_TIMEOUT_MS=45000
# Python RAG agent (contract knowledge retrieve). Disable to fall back to prompt-only.
RAG_ENABLED=true
RAG_BASE_URL=http://127.0.0.1:8000
RAG_TOP_K=5
RAG_TIMEOUT_MS=8000
